name: Build and publish Writerside docs

on:
  push:
    branches: ["main"]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: false

env:
  INSTANCE: "Writerside/v"
  DOCKER_VERSION: "latest"

jobs:
  build:
    runs-on: ubuntu-latest
    outputs:
      artifact: ${{ steps.define-ids.outputs.artifact }}
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Define artifact id
        id: define-ids
        run: |
          INSTANCE_ID="${INSTANCE#*/}"
          INSTANCE_ID_UPPER="$(echo "$INSTANCE_ID" | tr '[:lower:]' '[:upper:]')"
          ARTIFACT="webHelp${INSTANCE_ID_UPPER}2-all.zip"
          echo "artifact=$ARTIFACT" >> "$GITHUB_OUTPUT"

      - name: Build docs using Writerside
        uses: JetBrains/writerside-github-action@v4
        with:
          instance: ${{ env.INSTANCE }}
          docker-version: ${{ env.DOCKER_VERSION }}

      - name: Upload Writerside artifact
        uses: actions/upload-artifact@v4
        with:
          name: writerside-docs
          path: artifacts/${{ steps.define-ids.outputs.artifact }}
          retention-days: 7

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - name: Download Writerside artifact
        uses: actions/download-artifact@v4
        with:
          name: writerside-docs
          path: artifacts

      - name: Unzip website
        run: unzip -O UTF-8 -qq "artifacts/${{ needs.build.outputs.artifact }}" -d site

      - name: Configure GitHub Pages
        uses: actions/configure-pages@v5

      - name: Upload GitHub Pages artifact
        uses: actions/upload-pages-artifact@v4
        with:
          path: site

      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
