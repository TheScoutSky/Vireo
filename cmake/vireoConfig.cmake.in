@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(_vireo_sdl2_user_prefix "$ENV{HOME}/.local/sdl2")
if(EXISTS "${_vireo_sdl2_user_prefix}/lib/cmake/SDL2/SDL2Config.cmake")
    list(PREPEND CMAKE_PREFIX_PATH "${_vireo_sdl2_user_prefix}")
endif()

find_dependency(SDL2 2.0 CONFIG)
find_dependency(SDL2_image 2.0 CONFIG)

include("${CMAKE_CURRENT_LIST_DIR}/vireoTargets.cmake")

check_required_components(vireo)
